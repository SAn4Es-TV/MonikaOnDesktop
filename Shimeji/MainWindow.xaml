<Window x:Class="Monika.Shimeji.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monika.Shimeji"
        mc:Ignorable="d"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        Title="MainWindow" Height="300" Width="400" 
        MouseLeftButtonDown="Window_MouseLeftButtonDown" 
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseDown="Window_MouseDown"
        MouseUp="Window_MouseUp">
    <Grid
               RenderTransformOrigin="0.5,0">
        <Image Name="MonikaSprite" Source="/images/m_sticker_1.png" Width="119" Height="168"
               VerticalAlignment="Bottom"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               Cursor="Hand"
               RenderTransformOrigin="0.5,0"
               IsHitTestVisible="True">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="MainScale" ScaleX="1" ScaleY="1"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Grid.RenderTransform>

            <TransformGroup>
                <ScaleTransform x:Name="BodyScale" ScaleX="1" ScaleY="1"/>
                <RotateTransform x:Name="BodyRotate" Angle="0"/>
            </TransformGroup>
        </Grid.RenderTransform>
    </Grid>
</Window>
