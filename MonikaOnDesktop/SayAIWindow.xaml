<Window
    x:Class="MonikaOnDesktop.SayAIWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonikaOnDesktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SayAIWindow"
    Width="400"
    Height="150"
    MouseDown="Window_MouseDown"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="Aqua" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="#01ffffff">
                            <local:OutlinedTextBlock
                                x:Name="buttText"
                                Margin="0,0,0,0"
                                Fill="White"
                                FontFamily="{StaticResource riffic}"
                                FontSize="24"
                                Stroke="#FFBB5599"
                                StrokeThickness="2.5"
                                Text="{TemplateBinding Content}" />
                            <local:OutlinedTextBlock
                                x:Name="buttText1"
                                Margin="0,0,0,0"
                                Fill="White"
                                FontFamily="{StaticResource riffic}"
                                FontSize="24"
                                Stroke="#FFBB5599"
                                StrokeThickness="0"
                                Text="{TemplateBinding Content}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttText" Property="Stroke" Value="#FFFFAACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBE6F4" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border
        Background="#FFFFE6F4"
        BorderBrush="#FFFFAACC"
        BorderThickness="4">
        <StackPanel>
            <TextBlock
                x:Name="InputName"
                Margin="10"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource aller}"
                FontSize="28"
                Text="{DynamicResource loc_AI_Prompt}" />

            <Grid Margin="20,0,20,0">
                <Image
                    VerticalAlignment="Bottom"
                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                    Source="/images/horizontal_poem_bar.png" />
                <TextBox
                    x:Name="InputTextBox"
                    Margin="10"
                    AcceptsReturn="True"
                    Background="{x:Null}"
                    BorderBrush="{x:Null}"
                    BorderThickness="0"
                    FontFamily="{StaticResource halogen}"
                    FontSize="20"
                    KeyDown="InputTextBox_KeyDown"
                    MaxLines="1"
                    SelectionBrush="Transparent"
                    SelectionTextBrush="#FFBB5599"
                    Text=""
                    TextAlignment="Center" />
            </Grid>
            <WrapPanel HorizontalAlignment="Center">
                <Button
                    Margin="0,0,20,0"
                    Click="Button_Click_1"
                    Content="{DynamicResource loc_Btn_Cancel}" />
                <Button Click="Button_Click" Content="{DynamicResource loc_Btn_Say}" />
            </WrapPanel>
        </StackPanel>
    </Border>
</Window>
