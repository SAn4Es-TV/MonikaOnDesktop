    <Resource Include="langs\ru-RU.xaml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Resource>
    <Resource Include="MultiplyEffect.ps">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="outlineeffect.ps">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
