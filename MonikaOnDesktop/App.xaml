<Application
    x:Class="MonikaOnDesktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:MonikaOnDesktop"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Langs/ru-RU.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="halogen">pack://application:,,,/fonts/#Halogen</FontFamily>
            <FontFamily x:Key="aller">pack://application:,,,/fonts/#Aller Cyrillic</FontFamily>
            <FontFamily x:Key="riffic">pack://application:,,,/fonts/#My Font</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
