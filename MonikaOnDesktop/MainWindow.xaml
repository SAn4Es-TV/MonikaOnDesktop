<Window
    x:Class="MonikaOnDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonikaOnDesktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="600"
    Height="400"
    AllowsTransparency="True"
    Background="Transparent"
    IsHitTestVisible="True"
    MouseWheel="Window_MouseWheel"
    ShowInTaskbar="False"
    SizeChanged="Window_SizeChanged"
    SizeToContent="WidthAndHeight"
    Topmost="True"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="mainBorder"
                            Background="#FFFFE6F4"
                            BorderBrush="#FFFFAACC"
                            BorderThickness="4">
                            <TextBlock
                                Margin="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource aller}"
                                FontSize="20"
                                Text="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="mainBorder" Property="Background" Value="White" />
                                <Setter TargetName="mainBorder" Property="BorderBrush" Value="#FFFFAACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid
        Name="mainApp"
        Width="600"
        Height="400"
        IsHitTestVisible="True">
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="MainScale" CenterX="1" CenterY="1" ScaleX="1" ScaleY="1" />
        </Grid.LayoutTransform>
        <Grid x:Name="MonikaContainer">
            <local:AlphaTapImage x:Name="ImgChair" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgHairBack" RenderOptions.BitmapScalingMode="Linear" />
            <ItemsControl x:Name="ItemsPreAcs">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <local:AlphaTapImage x:Name="ImgBody" RenderOptions.BitmapScalingMode="Linear" />
            <ItemsControl x:Name="ItemsBseAcs">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <local:AlphaTapImage x:Name="ImgC_Body" RenderOptions.BitmapScalingMode="Linear" />
            <ItemsControl x:Name="ItemsBbhAcs">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <local:AlphaTapImage x:Name="ImgArmL" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgArmR" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgC_ArmL" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgC_ArmR" RenderOptions.BitmapScalingMode="Linear" />

            <local:AlphaTapImage x:Name="ImgHead" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgTable" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgTableS" RenderOptions.BitmapScalingMode="Linear" />

            <local:AlphaTapImage x:Name="ImgArmL_Top" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgArmR_Top" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgC_ArmL_Top" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgC_ArmR_Top" RenderOptions.BitmapScalingMode="Linear" />

            <local:AlphaTapImage x:Name="ImgBody1" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgC_Body1" RenderOptions.BitmapScalingMode="Linear" />

            <local:AlphaTapImage x:Name="ImgHairFront" RenderOptions.BitmapScalingMode="Linear" />
            <ItemsControl x:Name="ItemsAfhAcs">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <local:AlphaTapImage x:Name="ImgEyes" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgNose" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgEyebrows" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgMouth" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgTears" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgBlush" RenderOptions.BitmapScalingMode="Linear" />

            <local:AlphaTapImage x:Name="ImgArmL_Top2" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgArmR_Top2" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgC_ArmL_Top2" RenderOptions.BitmapScalingMode="Linear" />
            <local:AlphaTapImage x:Name="ImgC_ArmR_Top2" RenderOptions.BitmapScalingMode="Linear" />

            <ItemsControl x:Name="ItemsAseAcs" IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid IsHitTestVisible="False" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl x:Name="ItemsPstAcs" IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid IsHitTestVisible="False" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
        <Grid
            x:Name="saybox"
            Width="500"
            Height="100"
            Margin="25,0,25,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom">
            <Image
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Source="pack://application:,,,/images/textbox.png" />
            <TextBlock
                x:Name="sayboxText"
                MaxWidth="460"
                MaxHeight="80"
                Margin="0,15,0,10"
                FontFamily="{StaticResource halogen}"
                FontSize="24"
                Foreground="White"
                LineHeight="25"
                LineStackingStrategy="BlockLineHeight"
                SizeChanged="sayboxText_SizeChanged"
                Text="ghjkl"
                TextWrapping="Wrap">
                <TextBlock.Effect>
                    <local:OutlineEffect
                        x:Name="MyOutline"
                        Softness="0.3"
                        Thickness="1" />
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock
                Margin="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#01000000"
                FontFamily="{StaticResource halogen}"
                Foreground="#FFBB5599"
                MouseDown="TextBlock_MouseDown"
                Text="Skip" />
        </Grid>
        <StackPanel x:Name="MenuStackPanel" Margin="70,0,70,0" />
        <Border
            x:Name="InputContainer"
            Width="300"
            Height="90"
            Margin="70,70,70,0"
            VerticalAlignment="Top"
            Background="#FFFFE6F4"
            BorderBrush="#FFFFAACC"
            BorderThickness="4"
            Visibility="Collapsed">
            <StackPanel Margin="10" Visibility="Visible">

                <TextBlock
                    x:Name="InputText"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource aller}"
                    FontSize="20"
                    Text="счясчя" />
                <Grid Margin="0,0,0,0">
                    <Image
                        VerticalAlignment="Bottom"
                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                        Source="/images/horizontal_poem_bar.png" />
                    <TextBox
                        x:Name="InputField"
                        Margin="5"
                        AcceptsReturn="False"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        BorderThickness="0"
                        FontFamily="{StaticResource halogen}"
                        FontSize="20"
                        KeyDown="InputField_KeyDown"
                        MaxLines="1"
                        SelectionBrush="Transparent"
                        SelectionTextBrush="#FFBB5599"
                        Text=""
                        TextAlignment="Center"
                        TextWrapping="NoWrap" />
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</Window>
