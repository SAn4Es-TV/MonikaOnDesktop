<UserControl x:Class="MonikaOnDesktop.AISettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonikaOnDesktop"
             mc:Ignorable="d" 
                          d:DesignHeight="336" d:DesignWidth="510">
    <UserControl.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <WrapPanel Margin="0,3,0,0">
                            <Image Width="17" x:Name="img" Source="/images/check_selected_foreground.png" Visibility="Hidden"/>
                            <TextBlock Text="{TemplateBinding Content}" x:Name="buttText" FontSize="17" FontFamily="Halogen" VerticalAlignment="Center" Margin="0,0,0,0" Foreground="#FFA5A5A5"/>
                        </WrapPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="buttText" Property="Foreground" Value="#FFBB5599"/>
                                <Setter TargetName="img" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttText" Property="Foreground" Value="#FFBB5599"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>

            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}" >
                        <Image  Source="/images/horizontal_hover_thumb.png" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarBtn" TargetType="{x:Type RepeatButton}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Grid.Background>
                                <ImageBrush ImageSource="/images/horizontal_poem_bar.png" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            </Grid.Background>
                            <Track x:Name="PART_Track" IsDirectionReversed="true" ViewportSize="NaN">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Margin="2" Style="{StaticResource ScrollBarBtn}" Command="ScrollBar.PageUpCommand" Opacity="1" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Margin="2" Style="{StaticResource ScrollBarBtn}" Command="ScrollBar.PageDownCommand" Opacity="1" />
                                </Track.IncreaseRepeatButton>

                                <Track.Thumb >
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="sub">
            <Setter Property="Background" Value="Aqua"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="#01ffffff">
                            <local:OutlinedTextBlock x:Name="buttText" Text="{TemplateBinding Content}" Margin="0,0,0,0" Stroke="#FFBB5599" StrokeThickness="2.5" FontFamily="My Font" Fill="White" FontSize="24" />
                            <local:OutlinedTextBlock x:Name="buttText1" Text="{TemplateBinding Content}" Margin="0,0,0,0" Stroke="#FFBB5599" StrokeThickness="0" FontFamily="My Font" Fill="White" FontSize="24" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="Transparent" >
        <WrapPanel Margin="20">
            <StackPanel Margin="0,0,70,0">
                <Button Style="{StaticResource sub}" Content="{DynamicResource loc_Cat_Main}"/>
                <CheckBox Content="{DynamicResource loc_Chk_AI_Enable}" IsChecked="{Binding Settings.AI}"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,0">
                <Button Style="{StaticResource sub}" Content="{DynamicResource loc_Cat_Token}"/>
                <Border Padding="1" BorderThickness="0">
                    <Border.Background>
                        <ImageBrush ImageSource="/images/textbox_background.png" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border.Background>

                    <TextBox BorderThickness="0" Text="{Binding Settings.token}" FontFamily="Halogen" FontSize="17" Width="150" Foreground="#FFA5A5A5" BorderBrush="{x:Null}" Background="{x:Null}" SelectionBrush="Transparent" SelectionTextBrush="#FFBB5599"/>

                </Border>
                <Button Style="{StaticResource sub}" Content="{DynamicResource loc_Cat_Port}" Margin="0,10,0,0"/>
                <Border Padding="1" BorderThickness="0">
                    <Border.Background>
                        <ImageBrush ImageSource="/images/textbox_background.png" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border.Background>

                    <TextBox BorderThickness="0" Text="{Binding Settings.port}" FontFamily="Halogen" FontSize="17" Width="150" Foreground="#FFA5A5A5" BorderBrush="{x:Null}" Background="{x:Null}" SelectionBrush="Transparent" SelectionTextBrush="#FFBB5599"/>

                </Border>
            </StackPanel>
        </WrapPanel>
    </Grid>
</UserControl>
