<Window
    x:Class="MonikaOnDesktop.WearSelectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonikaOnDesktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{DynamicResource loc_Title_Appearance}"
    Width="800"
    Height="480"
    ResizeMode="CanMinimize"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="MinHeight" Value="160" />
            <Setter Property="Height" Value="120" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Image Source="pack://application:,,,/images/vertical_poem_thumb.png" Stretch="Fill" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarBtn" TargetType="{x:Type RepeatButton}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="15">
                            <Grid.Background>
                                <ImageBrush ImageSource="pack://application:,,,/images/vertical_poem_bar.png" />
                            </Grid.Background>
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="true"
                                ViewportSize="NaN">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton
                                        Margin="2"
                                        Command="ScrollBar.PageUpCommand"
                                        Opacity="1"
                                        Style="{StaticResource ScrollBarBtn}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton
                                        Margin="2"
                                        Command="ScrollBar.PageDownCommand"
                                        Opacity="1"
                                        Style="{StaticResource ScrollBarBtn}" />
                                </Track.IncreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Width="14" Style="{StaticResource ScrollBarThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UpperMenuModeButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Aqua" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="mainBorder"
                            Padding="5"
                            Background="Transparent">
                            <Border x:Name="subBorder" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="subBorder" Property="Background" Value="White" />
                                <Setter TargetName="mainBorder" Property="Background" Value="#FFBB5599" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="subBorder" Property="Background" Value="White" />
                                <Setter TargetName="mainBorder" Property="Background" Value="#FFFFAACC" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="subBorder" Property="Background" Value="White" />
                                <Setter TargetName="mainBorder" Property="Background" Value="#FFFFAACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBE6F4" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Aqua" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border
                            x:Name="mainBorder"
                            Padding="5"
                            Background="Transparent">
                            <Border x:Name="subBorder" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="subBorder" Property="Background" Value="White" />
                                <Setter TargetName="mainBorder" Property="Background" Value="#FFBB5599" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="subBorder" Property="Background" Value="White" />
                                <Setter TargetName="mainBorder" Property="Background" Value="#FFFFAACC" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="subBorder" Property="Background" Value="White" />
                                <Setter TargetName="mainBorder" Property="Background" Value="#FFFFAACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBE6F4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Aqua" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="subBorder" Background="Transparent">
                            <Grid Background="#01ffffff">
                                <local:OutlinedTextBlock
                                    x:Name="buttText"
                                    Margin="0,0,0,0"
                                    Fill="White"
                                    FontFamily="{StaticResource riffic}"
                                    FontSize="22"
                                    Stroke="#FFBB5599"
                                    StrokeThickness="1.5"
                                    Text="{TemplateBinding Content}" />
                                <local:OutlinedTextBlock
                                    x:Name="buttText1"
                                    Margin="0,0,0,0"
                                    Fill="White"
                                    FontFamily="{StaticResource riffic}"
                                    FontSize="22"
                                    Stroke="#FFBB5599"
                                    StrokeThickness="0"
                                    Text="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttText" Property="Stroke" Value="#FFFFAACC" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter TargetName="buttText" Property="Stroke" Value="#FFBB5599" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBE6F4" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/images/menu.png" />
        </Grid.Background>
        <StackPanel
            Margin="20,0,0,30"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom">
            <Button
                x:Name="Hair"
                Click="Tab_Click"
                Content="{DynamicResource loc_Wear_Hair}"
                Style="{StaticResource MenuButton}" />
            <Button
                x:Name="Ahoge"
                Click="Tab_Click"
                Content="{DynamicResource loc_Wear_Ahoge}"
                Style="{StaticResource MenuButton}" />
            <Button
                x:Name="Ribbon"
                Click="Tab_Click"
                Content="{DynamicResource loc_Wear_Ribbon}"
                Style="{StaticResource MenuButton}" />
            <Button
                x:Name="Hat"
                Click="Tab_Click"
                Content="{DynamicResource loc_Wear_Hat}"
                Style="{StaticResource MenuButton}" />
            <Button
                x:Name="Wear"
                Click="Tab_Click"
                Content="{DynamicResource loc_Wear_Cloth}"
                Style="{StaticResource MenuButton}" />
            <Button
                x:Name="Other"
                Click="Tab_Click"
                Content="{DynamicResource loc_Wear_Other}"
                Style="{StaticResource MenuButton}" />

            <Button
                x:Name="Save"
                Click="SubmitButton_Click"
                Content="{DynamicResource loc_Btn_Save}"
                Style="{StaticResource MenuButton}" />
            <Button
                x:Name="Exit"
                Click="CancelButton_Click"
                Content="{DynamicResource loc_Btn_Exit}"
                Style="{StaticResource MenuButton}" />
        </StackPanel>
        <Grid>
            <ScrollViewer
                x:Name="ScrollHair"
                Width="550"
                Height="336"
                Margin="0,0,20,30"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                VerticalScrollBarVisibility="Auto">
                <WrapPanel
                    x:Name="libHair"
                    Width="550"
                    VerticalAlignment="Stretch" />
            </ScrollViewer>
            <ScrollViewer
                x:Name="ScrollWear"
                Width="550"
                Height="336"
                Margin="0,0,20,30"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                VerticalScrollBarVisibility="Auto"
                Visibility="Hidden">
                <WrapPanel
                    x:Name="libWear"
                    Width="550"
                    VerticalAlignment="Stretch" />
            </ScrollViewer>
            <Grid.OpacityMask>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.0" Color="Transparent" />
                    <GradientStop Offset="0.1" Color="Black" />
                    <GradientStop Offset="0.9" Color="Black" />
                    <GradientStop Offset="1.0" Color="Transparent" />
                </LinearGradientBrush>
            </Grid.OpacityMask>
        </Grid>
        <local:OutlinedTextBlock
            Margin="0,10,20,00"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Fill="White"
            FontFamily="{StaticResource riffic}"
            FontSize="40"
            Stroke="#FFBB5599"
            StrokeThickness="2.5"
            Text="{DynamicResource loc_Title_Appearance}" />
        <local:OutlinedTextBlock
            Margin="0,10,20,00"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Fill="White"
            FontFamily="{StaticResource riffic}"
            FontSize="40"
            Stroke="#FFBB5599"
            StrokeThickness="0"
            Text="{DynamicResource loc_Title_Appearance}" />
        <Image
            Width="180"
            Height="180"
            Margin="60,10,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Source="pack://application:,,,/images/logo.png"
            Stretch="Fill" />

    </Grid>
</Window>
