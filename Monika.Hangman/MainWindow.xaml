<Window x:Class="Monika.Hangman.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monika.Hangman"
        mc:Ignorable="d"
        Title="Hangman" Height="560" Width="600" ResizeMode="CanMinimize"
        Topmost="True">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/hangman/hm_frame.png"/>
        </Grid.Background>
        <Image Name="hangman" Source="/hangman/hm_0.png"  VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,80"/>
        <TextBlock x:Name="missed" Text="Missed: " FontSize="30" FontFamily="Halogen" Margin="20,28,0,0" FontStyle="Italic"/>
        <TextBlock x:Name="word" Text="_ b _ _ a _ _" HorizontalAlignment="Center" FontSize="30" VerticalAlignment="Bottom" Margin="0,0,0,65" FontStyle="Italic" Foreground="#FFBB5599" FontFamily="Halogen"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <TextBlock Text="Guess a letter: " FontFamily="Halogen" FontSize="30" FontStyle="Italic"/>
            <TextBox x:Name="textBox" Text="" FontStyle="Italic" FontFamily="Halogen" FontSize="30" Background="Transparent" BorderThickness="0,0,0,0" MaxLength="1" Width="50"/>
            
                    
        </StackPanel>
    </Grid>
</Window>
